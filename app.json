{
  "expo": {
    "name": "efmg-expo",
    "slug": "ef-2.0",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LogoLobasNegroIco192.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/LogoLobasNegroIco192.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0F1A"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/LogoLobasNegroIco192.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/icon-light.png",
      "lang": "es"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-video",
      "@react-native-community/datetimepicker"
    ]
  }
}
{
  "hosting": {
    "site": "efmartinguemes",
    "public": "dist",

    "ignore": [
      "firebase.json",
      "**/.*"
    ],

    "headers": [
      {
        "source": "**/*.@(ttf|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      }
    ],

    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}